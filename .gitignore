# =============================================================================
# Guardify Private Media – .gitignore
# https://github.com/umang48/guardify-private-media
# =============================================================================

# ── OS & Editor files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# JetBrains IDEs (PhpStorm, IntelliJ)
.idea/
*.iml
*.iws

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs swap files
*~
*.swp
*.swo
*.bak

# ── Node / NPM (for build tooling, if added later) ───────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npmrc

# Build output
dist/
build/

# ── PHP / Composer ───────────────────────────────────────────────────────────
vendor/
composer.lock

# ── WordPress-specific ───────────────────────────────────────────────────────
# Don't commit the WordPress core or other plugins/themes
/wp-admin/
/wp-includes/
/wp-content/uploads/
/wp-content/upgrade/
/wp-content/themes/
/wp-content/plugins/*/
!/wp-content/plugins/guardify-private-media/

# Local wp-config
wp-config.php
wp-config-local.php

# ── Test & Coverage artifacts ─────────────────────────────────────────────────
/tests/
/bin/
.phpunit.result.cache
coverage/
.coverage

# ── Build & release artifacts ─────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar.bz2

# SVN checkout directory (WP.org deployment)
/svn/
/.svn/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── PHPStan / PHP_CodeSniffer config (keep or ignore per preference) ──────────
# phpstan.neon
# .phpcs.xml

# ── Local dev helpers ────────────────────────────────────────────────────────
local-config.php
local-wp-config.php
